{
  "name": "@dezin/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Dezin daemon — a tiny node:http server: health, project CRUD (node:sqlite), static artifact serving, and (next) the generate run loop.",
  "exports": {
    ".": "./src/index.ts"

{
  "name": "@dezin/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Dezin daemon — a tiny node:http server: health, project CRUD (node:sqlite), static artifact serving, and (next) the generate run loop.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start": "node --experimental-strip-types --experimental-sqlite --no-warnings src/start.ts",
    "test": "node --experimental-strip-types --experimental-sqlite --no-warnings --test 'test/*.test.ts'",
    "test:coverage": "node --experimental-strip-types --experimental-sqlite --no-warnings --experimental-test-coverage --test-coverage-exclude='**/*.test.*' --test-coverage-lines=79 --test-coverage-branches=67 --test-coverage-functions=35 --test 'test/*.test.ts'"
  },
  "dependencies": {
    "@ai-sdk/azure": "^4.0.5",
    "@ai-sdk/fal": "^3.0.3",
    "@ai-sdk/google": "^4.0.6",
    "@ai-sdk/google-vertex": "^5.0.6",
    "@ai-sdk/openai-compatible": "^3.0.3",
    "ai": "^7.0.11",
    "fflate": "^0.8.3",
    "kiwi-schema": "^0.5.0",
    "puppeteer-core": "^25.2.1",
    "undici": "^7.28.0"
  }
}

{
  "name": "@dezin/design",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Bundled Dezin design systems (9-section DESIGN.md + tokens) and a registry. Default = modern-minimal (Linear/Vercel).",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node --experimental-strip-types --no-warnings --test 'test/*.test.ts'",
    "test:coverage": "node --experimental-strip-types --no-warnings --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-exclude='**/*.test.*' --test-coverage-lines=59 --test-coverage-branches=55 --test-coverage-functions=55 --test 'test/*.test.ts'"
  }
}

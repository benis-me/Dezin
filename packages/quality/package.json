{
  "name": "@dezin/quality",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Dezin anti-AI-slop quality kernel: a deterministic artifact linter plus the lint→repair closed loop.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test 'test/*.test.ts'",
    "test:coverage": "node --experimental-strip-types --experimental-test-coverage --test-coverage-exclude='**/*.test.*' --test-coverage-lines=99 --test-coverage-branches=89 --test-coverage-functions=97 --test 'test/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json"
  }
}

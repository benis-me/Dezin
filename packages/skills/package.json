{
  "name": "@dezin/skills",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Lazy filesystem loader for Dezin skills (SKILL.md = flat frontmatter + workflow body). No YAML dependency.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node --experimental-strip-types --no-warnings --test 'test/*.test.ts'",
    "test:coverage": "node --experimental-strip-types --no-warnings --experimental-test-coverage --test-coverage-exclude='**/*.test.*' --test-coverage-lines=100 --test-coverage-branches=88 --test-coverage-functions=100 --test 'test/*.test.ts'"
  }
}

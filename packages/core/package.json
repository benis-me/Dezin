{
  "name": "@dezin/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Dezin domain types + a node:sqlite-backed local store (metadata only; artifacts live on disk).",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node --experimental-strip-types --experimental-sqlite --no-warnings --test 'test/*.test.ts'",
    "test:coverage": "node --experimental-strip-types --experimental-sqlite --no-warnings --experimental-test-coverage --test-coverage-exclude='**/*.test.*' --test-coverage-lines=84 --test-coverage-branches=63 --test-coverage-functions=74 --test 'test/*.test.ts'"
  }
}
